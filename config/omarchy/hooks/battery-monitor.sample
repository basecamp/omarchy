#!/bin/bash

# This hook is called with the current battery percentage and state every 30 seconds.
# To put it into use, remove .sample from the name.

BATTERY_LEVEL=$1
BATTERY_STATE=$2

if [[ $(powerprofilesctl get) != "power-saver" ]] &&
  [[ $BATTERY_STATE == "discharging" ]] &&
  ((BATTERY_LEVEL <= ${OMARCHY_POWER_SAVER_BATTERY_TRESHOLD:-20})); then
  powerprofilesctl set power-saver
fi
