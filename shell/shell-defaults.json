{
  "version": 1,
  "idle": {
    "screensaver": 150,
    "lock": 300
  },
  "bar": {
    "position": "top",
    "transparent": false,
    "centerAnchor": "clock",
    "layout": {
      "left": [
        {
          "id": "omarchy"
        },
        {
          "id": "workspaces"
        }
      ],
      "center": [
        {
          "id": "clock",
          "format": "dddd HH:mm",
          "formatAlt": "dd MMMM yyyy",
          "verticalFormat": "HH\n\u2014\nmm"
        },
        {
          "id": "weather"
        },
        {
          "id": "indicators",
          "items": [
            "dnd",
            "nightlight",
            "stayAwake",
            "screenrecording",
            "dictation"
          ]
        },
        {
          "id": "systemUpdate"
        }
      ],
      "right": [
        {
          "id": "tray"
        },
        {
          "id": "bluetoothPanel"
        },
        {
          "id": "networkPanel"
        },
        {
          "id": "audioPanel"
        },
        {
          "id": "monitorPanel"
        },
        {
          "id": "powerPanel"
        }
      ]
    }
  },
  "plugins": []
}
