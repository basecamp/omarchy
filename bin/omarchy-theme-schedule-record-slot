#!/bin/bash

# omarchy:summary=Record current theme to the active phase's slot
# omarchy:args=<theme-name>
# omarchy:hidden=true

# No `set -e`: slot learning is best-effort. We'd rather skip the update
# (with a breadcrumb to stderr) than fail and trigger 'Hook failed' in
# the calling omarchy-hook on every theme change.
set -uo pipefail

if [[ "${OMARCHY_THEME_SCHEDULE_TICK:-}" == "1" ]]; then
  exit 0
fi

if ! systemctl --user is-enabled --quiet omarchy-theme-schedule.timer 2>/dev/null; then
  exit 0
fi

theme_name="${1:?theme name required}"

if ! loc=$(omarchy-theme-schedule-location 2>/dev/null); then
  echo "omarchy-theme-schedule-record-slot: location helper failed — skipping slot update" >&2
  exit 0
fi
lat="${loc%,*}"
lon="${loc#*,}"
today=$(date +%Y-%m-%d)
mapfile -t suntimes < <(omarchy-theme-schedule-suncalc "$lat" "$lon" "$today" 2>/dev/null)
if (( ${#suntimes[@]} < 2 )); then
  echo "omarchy-theme-schedule-record-slot: suncalc returned no output for $today at $lat,$lon — skipping slot update" >&2
  exit 0
fi
sunrise="${suntimes[0]}"
sunset="${suntimes[1]}"

if [[ "$sunrise" == "PERPETUAL_DAY" ]]; then
  phase="day"
elif [[ "$sunrise" == "PERPETUAL_NIGHT" ]]; then
  phase="night"
else
  now_epoch=$(date +%s)
  sr_epoch=$(date -d "$sunrise" +%s)
  ss_epoch=$(date -d "$sunset" +%s)
  if (( now_epoch >= sr_epoch && now_epoch < ss_epoch )); then
    phase="day"
  else
    phase="night"
  fi
fi

OMARCHY_CURRENT="$HOME/.config/omarchy/current"
mkdir -p "$OMARCHY_CURRENT"
echo "$theme_name" >"$OMARCHY_CURRENT/theme.$phase"
