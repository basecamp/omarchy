#!/bin/bash

# Display keyboard brightness level using SwayOSD on the current monitor.
# Usage: omarchy-swayosd-kbd-brightness <percent>

percent="$1"

case "$percent" in
  0)   label="OFF"    ;;
  1)   label="LOW"    ;;
  25)  label="MEDIUM" ;;
  100) label="HIGH"   ;;
  *)   label="${percent}%" ;;
esac

omarchy-swayosd-client \
  --custom-icon keyboard-brightness-symbolic \
  --custom-message "$label"
