#!/bin/bash

##
# Get the CWD of a child shell process.
# @param $1: The parent process ID (e.g., of the terminal emulator).
# @return: The absolute path of the shell's CWD on success.
##
get_terminal_cwd() {
  local parent_pid=$1
  local shell_pid
  shell_pid=$(pgrep --parent "$parent_pid")
  if [ -n "$shell_pid" ]; then
    readlink -f "/proc/$shell_pid/cwd" 2>/dev/null
  fi
}

##
# Get the CWD of a file manager by matching the window title to its DBus locations.
# @param $1: The title of the active window.
# @return: The matching absolute path on success.
##
get_file_manager_cwd() {
  local active_title=$1
  local raw_output open_paths
  raw_output=$(gdbus call --session --dest org.freedesktop.FileManager1 --object-path /org.freedesktop.FileManager1 --method org.freedesktop.DBus.Properties.Get "org.freedesktop.FileManager1" "OpenLocations" 2>/dev/null)
  if [ -z "$raw_output" ]; then return 1; fi

  open_paths=$(echo "$raw_output" | grep -oP "'file://[^']+'" | sed "s/'//g; s|file://||" | while read -r encoded_path; do printf '%b\n' "${encoded_path//%/\\x}"; done)
  while IFS= read -r path; do
    local dir_name
    dir_name=$(basename "$path")
    if [[ "$active_title" == *"$dir_name"* ]]; then
      echo "$path"
      return 0
    fi
  done <<< "$open_paths"
  return 1
}

##
# Get the open folder from VS Code by matching the active title against its list of open windows.
# @param $1: The title of the active window.
# @return: The matching absolute project path on success.
##
get_vscode_cwd() {
  local active_title=$1
  local state_file="$HOME/.config/Code/User/globalStorage/storage.json"
  if [ ! -f "$state_file" ]; then return 1; fi

  # CORRECTED: This jq command now uses the correct key 'folder'
  local open_uris
  open_uris=$(jq -r '.windowsState.openedWindows[] | .folder // .workspace.configPath' "$state_file" 2>/dev/null)
  
  while IFS= read -r uri; do
    if [[ -n "$uri" && "$uri" != "null" ]]; then
      local decoded_path project_path project_name
      decoded_path=$(printf '%b' "$(echo "$uri" | sed 's|file://||')")

      # Handle both direct folders and .code-workspace files
      if [[ -d "$decoded_path" ]]; then
          project_path="$decoded_path"
      else
          project_path=$(dirname "$decoded_path")
      fi
      project_name=$(basename "$project_path")

      # Check if the active window title contains the project's folder name.
      if [[ "$active_title" == *"$project_name"* ]]; then
        echo "$project_path"
        return 0
      fi
    fi
  done <<< "$open_uris"
  return 1
}

##
# Get the CWD of a generic GUI application as a fallback.
# @param $1: The process ID of the application.
# @return: The absolute path of the process's CWD on success.
##
get_generic_gui_cwd() {
  local pid=$1
  readlink -f "/proc/$pid/cwd" 2>/dev/null
}

##
# Main function to orchestrate CWD detection.
##
main() {
  local final_cwd="$HOME"
  local found_path
  
  local active_window_info
  active_window_info=$(hyprctl activewindow)
  
  local active_class
  active_class=$(echo "$active_window_info" | grep 'class:' | awk '{print $2}')
  
  local _pid
  _pid=$(echo "$active_window_info" | grep 'pid:' | awk '{print $2}')
  
  local active_title
  active_title=$(echo "$active_window_info" | grep "title:" | cut -d: -f2- | sed 's/^ *//')

  if [ -n "$active_class" ]; then
    case "$active_class" in
      kitty|Alacritty|Gnome-terminal|foot|wezterm)
        found_path=$(get_terminal_cwd "$_pid")
        ;;

      Code|code-oss|code|vscodium)
        found_path=$(get_vscode_cwd "$active_title")
        ;;

      org.gnome.Nautilus|org.kde.dolphin|Thunar)
        found_path=$(get_file_manager_cwd "$active_title")
        ;;

      *)
        if [ -n "$_pid" ]; then
            found_path=$(get_generic_gui_cwd "$_pid")
        fi
        ;;
    esac
  fi

  if [ -n "$found_path" ]; then
    final_cwd="$found_path"
  fi

  echo "$final_cwd"
}

main "$@"