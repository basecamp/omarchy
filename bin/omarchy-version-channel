#!/bin/bash

# omarchy:summary=Print the active Omarchy package channel

if grep -q "https://pkgs.omarchy.org/stable/" /etc/yum.repos.d/omarchy.repo 2>/dev/null; then
  echo "stable"
elif grep -q "https://pkgs.omarchy.org/rc/" /etc/yum.repos.d/omarchy.repo 2>/dev/null; then
  echo "rc"
elif grep -q "https://pkgs.omarchy.org/edge/" /etc/yum.repos.d/omarchy.repo 2>/dev/null; then
  echo "edge"
else
  echo "unknown"
fi
