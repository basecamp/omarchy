#!/bin/bash

# omarchy:summary=Launch an app on a special workspace, or toggle/move an existing window to it
# omarchy:args=<window-pattern> <special-workspace> [launch-command]

if (($# < 2)); then
  echo "Usage: omarchy-launch-or-focus-special-workspace [window-pattern] [special-workspace] [launch-command]"
  exit 1
fi

WINDOW_PATTERN="$1"
SPECIAL_WORKSPACE="$2"
LAUNCH_COMMAND="${*:3}"
LAUNCH_COMMAND="${LAUNCH_COMMAND:-"uwsm-app -- $WINDOW_PATTERN"}"

read -r WINDOW_ADDRESS APP_WORKSPACE < <(hyprctl clients -j | jq -r --arg p "$WINDOW_PATTERN" '[.[]|select((.class|test("\\b" + $p + "\\b";"i")) or (.title|test("\\b" + $p + "\\b";"i")))][0]|"\(.address // "") \(.workspace.name // "")"')

if [[ -n $WINDOW_ADDRESS ]]; then
  if [[ "$APP_WORKSPACE" == "special:$SPECIAL_WORKSPACE" ]]; then
    hyprctl dispatch togglespecialworkspace "$SPECIAL_WORKSPACE"
  else
    hyprctl dispatch movetoworkspacesilent "special:$SPECIAL_WORKSPACE,address:$WINDOW_ADDRESS"
    hyprctl dispatch togglespecialworkspace "$SPECIAL_WORKSPACE"
  fi
else
  hyprctl dispatch togglespecialworkspace "$SPECIAL_WORKSPACE"
  eval exec setsid $LAUNCH_COMMAND
fi
