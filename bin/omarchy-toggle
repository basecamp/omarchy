#!/bin/bash

# omarchy:summary=Toggle Omarchy features between enabled and disabled
# omarchy:args=<flag-name>

if (($# < 1)); then
  echo "Usage: omarchy-toggle <flag-name>" >&2
  exit 1
fi

FLAG_NAME="$1"
FLAG="$HOME/.local/state/omarchy/toggles/$FLAG_NAME"

if [[ -f $FLAG ]]; then
  rm -f "$FLAG"
else
  mkdir -p "$(dirname "$FLAG")"
  touch "$FLAG"
fi
