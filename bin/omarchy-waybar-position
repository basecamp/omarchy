#!/bin/bash

# omarchy:summary=Set Waybar position
# omarchy:group=waybar
# omarchy:name=position
# omarchy:args=<top|bottom|left|right>
# omarchy:examples=omarchy-waybar-position top | omarchy waybar position bottom

set -e

WAYBAR_CONFIG="$HOME/.config/waybar/config.jsonc"

position=$1

case "$position" in
  top|bottom|left|right) ;;
  *)
    echo "Usage: omarchy-waybar-position top|bottom|left|right" >&2
    exit 1
    ;;
esac

# Reset config before making adjustments
cp "$OMARCHY_PATH/config/waybar/config.jsonc" "$WAYBAR_CONFIG"

if [[ $position == "left" || $position == "right" ]]; then
  height=0
  horizontal=false
else
  height=26
  horizontal=true
fi

sed -i -E "s/(\"position\"[[:space:]]*:[[:space:]]*\")(top|bottom|left|right)(\")/\\1${position}\\3/" "$WAYBAR_CONFIG"
sed -i -E "s/(\"height\"[[:space:]]*:[[:space:]]*)[0-9]+/\\1${height}/" "$WAYBAR_CONFIG"
sed -i -E '/"width"[[:space:]]*:/d' "$WAYBAR_CONFIG"

if [[ $horizontal == true ]]; then
  # Change clock format to horizontal
  sed -i -E '/"clock"[[:space:]]*:[[:space:]]*\{/,/\}/ s/"format"[[:space:]]*:[[:space:]]*"[^"]*"/"format": "{:L%A %H:%M}"/' "$WAYBAR_CONFIG"
else
  sed -i -E '/"height"[[:space:]]*:/a\  "width": 28,' "$WAYBAR_CONFIG"

  # Change clock format to vertical
  sed -i -E '/"clock"[[:space:]]*:[[:space:]]*\{/,/\}/ s/"format"[[:space:]]*:[[:space:]]*"[^"]*"/"format": "{:%H\\n  —\\n%M}"/' "$WAYBAR_CONFIG"
fi

omarchy-restart-waybar
