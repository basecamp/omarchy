#!/bin/bash

# omarchy:summary=Update the Dell XPS haptic touchpad intensity.
# omarchy:args=[0-100]
# omarchy:requires-sudo=true

SERVICE_NAME="dell-xps-haptic-touchpad.service"
ENV_PATH="/etc/omarchy-dell-haptic-touchpad.env"
CONFIG_PATH="$HOME/.config/omarchy/dell-haptic.conf"
DEFAULT_INTENSITY=90
OMARCHY_PATH=${OMARCHY_PATH:-$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)}

read_current_intensity() {
  local line=""
  local value=""

  [[ -f $CONFIG_PATH ]] || {
    printf '%s\n' "$DEFAULT_INTENSITY"
    return 0
  }

  while IFS= read -r line; do
    line=${line#${line%%[![:space:]]*}}
    line=${line%${line##*[![:space:]]}}
    [[ -z $line || ${line:0:1} == "#" || $line != *=* ]] && continue

    if [[ ${line%%=*} == "INTENSITY" ]]; then
      value=${line#*=}
      value=${value#${value%%[![:space:]]*}}
      value=${value%${value##*[![:space:]]}}

      if [[ $value =~ ^[0-9]+$ ]]; then
        printf '%s\n' "$value"
        return 0
      fi
    fi
  done < "$CONFIG_PATH"

  printf '%s\n' "$DEFAULT_INTENSITY"
}

validate_intensity() {
  local value=$1

  if ! [[ $value =~ ^[0-9]+$ ]] || (( value < 0 || value > 100 )); then
    echo "Haptic intensity must be an integer from 0 to 100." >&2
    exit 1
  fi
}

service_uses_user_config() {
  local unit_text=""

  unit_text=$(systemctl cat "$SERVICE_NAME" 2>/dev/null || true)
  [[ $unit_text == *"EnvironmentFile=-$ENV_PATH"* ]]
}

ensure_service_configured() {
  if ! service_uses_user_config; then
    source "$OMARCHY_PATH/install/config/hardware/dell/fix-xps-haptic-touchpad.sh"
  fi

  service_uses_user_config
}

write_config() {
  local intensity=$1

  install -d -m 755 "$(dirname -- "$CONFIG_PATH")"
  printf '# Dell XPS touchpad haptic intensity.\n# Valid range: 0-100.\nINTENSITY=%s\n' "$intensity" > "$CONFIG_PATH"
}

write_env_file() {
  local tmpfile=""

  tmpfile=$(mktemp)
  printf 'OMARCHY_HAPTIC_HOME=%s\n' "$HOME" > "$tmpfile"
  sudo install -D -m 644 "$tmpfile" "$ENV_PATH"
  rm -f "$tmpfile"
}

reset_trackpad() {
  if command -v omarchy-restart-trackpad >/dev/null 2>&1; then
    omarchy-restart-trackpad
  fi
}

if ! omarchy-hw-dell-xps-haptic-touchpad; then
  echo "Dell XPS haptic touchpad hardware not detected." >&2
  exit 1
fi

if ! ensure_service_configured; then
  echo "Dell XPS haptic touchpad service is not available." >&2
  exit 1
fi

if [[ -n ${1:-} ]]; then
  intensity=$1
else
  intensity=$(read_current_intensity)
fi

validate_intensity "$intensity"
write_config "$intensity"
write_env_file
reset_trackpad
sudo systemctl restart "$SERVICE_NAME"

printf 'Updated Dell haptic intensity to %s.\n' "$intensity"
