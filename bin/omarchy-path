#!/bin/bash

# omarchy:summary=Print PATH entries one per numbered line
# omarchy:group=path
# omarchy:examples=omarchy path

if [[ -z ${PATH:-} ]]; then
  exit 0
fi

# Append a sentinel so trailing empty entries (e.g. "/a:/b:") survive splitting.
IFS=: read -ra entries <<<"${PATH}:_"
unset 'entries[-1]'

for i in "${!entries[@]}"; do
  printf '%d. %s\n' "$((i + 1))" "${entries[i]:-.}"
done
