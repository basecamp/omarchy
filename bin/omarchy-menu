  register_item "" "root" menu "" "Go" "" "" ""

  menu_action "root" "root.apps" "󰀻" "Apps" "omarchy-launch-walker -p 'Launch…'" "applications launch app launcher"
  menu_group "root" "root.learn" "󰧑" "Learn" "manual docs help reference"
  menu_group "root" "root.trigger" "󱓞" "Trigger" "actions capture share toggle hardware reminder"
  menu_group "root" "root.style" "" "Style" "theme background font waybar hyprland appearance"
  menu_group "root" "root.setup" "" "Setup" "settings configure defaults wifi bluetooth audio"
  menu_group "root" "root.install" "󰉉" "Install" "package app service browser editor terminal development gaming"
  menu_group "root" "root.remove" "󰭌" "Remove" "uninstall package app browser development gaming"
  menu_group "root" "root.update" "" "Update" "upgrade refresh restart channel firmware timezone"
  menu_action "root" "root.about" "" "About" "show_about" "about omarchy system information"
  menu_group "root" "root.system" "" "System" "lock logout restart shutdown suspend hibernate power"
}

