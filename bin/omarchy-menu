add_install_ai_menu() {
  local ollama_pkg
  ollama_pkg=$(
    (omarchy-cmd-present nvidia-smi && echo ollama-cuda) ||
      (omarchy-cmd-present rocminfo && echo ollama-rocm) ||
      echo ollama
  )
  menu_action "install.ai" "install.ai.dictation" "" "Dictation" "present_terminal omarchy-voxtype-install" "install ai dictation voice"
  menu_action "install.ai" "install.ai.lm-studio" "󱚤" "LM Studio" "install 'LM Studio' lmstudio-bin" "install ai lm studio"
  menu_action "install.ai" "install.ai.ollama" "󱚤" "Ollama" "install Ollama $ollama_pkg" "install ai ollama"
  menu_action "install.ai" "install.ai.crush" "󱚤" "Crush" "install Crush crush-bin" "install ai crush"
}

