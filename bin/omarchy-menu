show_remove_menu() {
  case $(menu "Remove" "¾░Żć  Package\n’ē©  Web App\n’Æē  TUI\n¾░Ą«  Development\n’äø  Gaming\n¾░Åō  Preinstalls\nŅ░Æ  Dictation\n¾░Ėī  Theme\n¾░Ź▓  Windows\n¾░łĘ  Fingerprint\nŅ¼æ  Fido2") in
