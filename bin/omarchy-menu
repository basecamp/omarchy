show_remove_menu() {
  case $(menu "Remove" "ґ░гЗ  Package\nяЙи  Web App\nяТЙ  TUI\nґ░╡о  Development\nяДЫ  Gaming\nґ░ПУ  Preinstalls\nю░Т  Dictation\nґ░╕М  Theme\nґ░Н▓  Windows\nґ░И╖  Fingerprint\nюмС  Fido2") in
  *Package*) terminal omarchy-pkg-remove ;;
  *Web*) present_terminal omarchy-webapp-remove ;;
  *TUI*) present_terminal omarchy-tui-remove ;;
