show_about() {
  omarchy-launch-about
}

show_system_menu() {
  local options="ґ▒ДД  Screensaver\nяАг  Lock"
  ! omarchy-toggle-enabled suspend-off && options="$options\nґ░Т▓  Suspend"
  omarchy-hibernation-available && options="$options\nґ░дБ  Hibernate"
  options="$options\nґ░НГ  Logout\nґ░ЬЙ  Restart\nґ░Ре  Shutdown"

  case $(menu "System" "$options") in
  *Screensaver*) omarchy-launch-screensaver force ;;
  *Lock*) omarchy-system-lock ;;
  *Suspend*) systemctl suspend ;;
  *Hibernate*) systemctl hibernate ;;
  *Logout*) omarchy-system-logout ;;
  *Restart*) omarchy-system-reboot ;;
  *Shutdown*) omarchy-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "ґ░А╗  Apps\nґ░зС  Learn\nґ▒УЮ  Trigger\nюпП  Style\nюШХ  Setup\nґ░ЙЙ  Install\nґ░нМ  Remove\nяАб  Update\nюй┤  About\nяАС  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) walker -p "LaunchтАж" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *hardware*) show_hardware_menu ;;
  *share*) show_share_menu ;;
  *transcode*) show_transcode_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omarchy/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n $1 ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
