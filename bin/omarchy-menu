  case $(menu "Remove" "з░БЄ  Package\n№Ѕе  Web App\n№њЅ  TUI\nз░х«  Development\n№ёЏ  Gaming\nз░ЈЊ  Preinstalls\nЬ░њ  Dictation\nз░Иї  Theme\nз░Ї▓  Windows\nз░ѕи  Fingerprint\nЬгЉ  Fido2") in
