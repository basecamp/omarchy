# Allow user extensions to add/replace menu items and actions via menu_group,
# menu_link, menu_action, or by changing MENU_ACTIONS[id].
USER_EXTENSIONS="$HOME/.config/omarchy/extensions/menu.sh"

usage() {
  cat <<USAGE
Usage: omarchy-menu [menu-or-action]

Launch the Quickshell Omarchy menu. Pass a menu name (install, style, system,
capture, toggle, etc.) to open there, or an action id to run it directly.
USAGE
}

menu_layer_visible() {
  hyprctl layers -j 2>/dev/null | jq -e '.. | objects | select(.namespace? == "omarchy-menu")' >/dev/null
}

close_visible_quickshell_menu() {
  local socket_path="${XDG_RUNTIME_DIR:-/run/user/$UID}/omarchy-menu.sock"

  [[ -S $socket_path ]] || return 1
  menu_layer_visible || return 1
  printf '\t\t\t\t\n' | socat -u - "UNIX-CONNECT:$socket_path" >/dev/null 2>&1 || true
}

case "${1:-}" in
--help | -h)
  usage
  exit 0
  ;;
screenrecord | screenrecording | screen-record)
  close_visible_quickshell_menu || true
  stop_active_screenrecording && exit 0
  ;;
esac

menu_socket_path() {
  printf '%s/omarchy-menu.sock' "${XDG_RUNTIME_DIR:-/run/user/$UID}"
}

menu_qml_path() {
  printf '%s/default/quickshell/menu.qml' "$OMARCHY_PATH"
}

source_menu_extensions() {
  [[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"
}

build_and_extend_menu() {
  [[ $MENU_BUILT == true ]] && return

  build_menu
  source_menu_extensions
  MENU_BUILT=true
}

json_string() {
  local value="${1-}"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\t'/\\t}"
  value="${value//$'\r'/\\r}"
  value="${value//$'\n'/\\n}"
  printf '"%s"' "$value"
}

write_menu_json() {
  local signature="${1:-}"
  local id
  local first=true

  printf '{\n  "signature": '
  json_string "$signature"
  printf ',\n  "items": [\n'

  for id in "${MENU_ORDER[@]}"; do
    if [[ $first == true ]]; then
      first=false
    else
      printf ',\n'
    fi

    printf '    { "id": '
    json_string "$id"
    printf ', "parent": '
    json_string "${MENU_PARENT[$id]}"
    printf ', "kind": '
    json_string "${MENU_KIND[$id]}"
    printf ', "icon": '
    json_string "${MENU_ICON[$id]}"
    printf ', "label": '
    json_string "${MENU_LABEL[$id]}"
    printf ', "target": '
    json_string "${MENU_TARGET[$id]}"
    printf ', "keywords": '
    json_string "${MENU_KEYWORDS[$id]}"
    printf ', "description": '
    json_string "${MENU_DESCRIPTION[$id]}"
    printf ' }'
  done

  printf '\n  ],\n  "actions": {\n'
  first=true

  for id in "${MENU_ORDER[@]}"; do
    [[ ${MENU_KIND[$id]} == "action" ]] || continue

    if [[ $first == true ]]; then
      first=false
    else
      printf ',\n'
    fi

    printf '    '
    json_string "$id"
    printf ': '
    json_string "${MENU_ACTIONS[$id]}"
  done

  printf '\n  }\n}\n'
}

menu_json() {
  local signature="${1:-}"

  build_and_extend_menu
  write_menu_json "$signature"
}

route_target() {
  local route="${1,,}"
  route="${route//_/-}"

  case "$route" in
  "" | go | menu) printf 'root' ;;
  apps | app | applications) printf 'root.apps' ;;
  learn) printf 'root.learn' ;;
  trigger) printf 'root.trigger' ;;
  toggle | toggles) printf 'trigger.toggle' ;;
  hardware | hw) printf 'trigger.hardware' ;;
  share) printf 'trigger.share' ;;
  reminder) printf 'trigger.reminder' ;;
  reminder-set | remind) printf 'trigger.reminder.set' ;;
  capture | screenshot) printf 'trigger.capture' ;;
  screenrecord | screen-record | screenrecording) printf 'trigger.capture.screenrecord' ;;
  style) printf 'root.style' ;;
  theme | themes) printf 'style.theme' ;;
  background | wallpaper) printf 'style.background' ;;
  setup | settings) printf 'root.setup' ;;
  power | power-profile | power-profiles) printf 'setup.power' ;;
  install) printf 'root.install' ;;
  remove | uninstall) printf 'root.remove' ;;
  update | restart | refresh) printf 'root.update' ;;
  about) printf 'root.about' ;;
  system | power-menu) printf 'root.system' ;;
  *) printf '%s' "$route" ;;
  esac
}

route_field() {
  local target="$1"
  local field="$2"
  local cache_file

  ensure_menu_cache
  cache_file="$(menu_cache_file)"
  jq -r --arg id "$target" --arg field "$field" '.items[] | select(.id == $id) | .[$field] // empty' "$cache_file"
}

route_kind() {
  route_field "$1" kind
}

route_link_target() {
  route_field "$1" target
}

menu_cache_signature() {
  local path

  for path in \
    "$OMARCHY_PATH/bin/omarchy-menu" \
    "$USER_EXTENSIONS"; do
    if [[ -f $path ]]; then
      sha256sum "$path"
    else
      printf '%s\tmissing\n' "$path"
    fi
  done
}

menu_cache_dir() {
  printf '%s/omarchy/menu' "${XDG_CACHE_HOME:-$HOME/.cache}"
}

menu_cache_file() {
  printf '%s/menu.json' "$(menu_cache_dir)"
}

refresh_menu_cache() {
  local cache_dir
  local cache_file
  local signature

  cache_dir=$(menu_cache_dir)
  cache_file=$(menu_cache_file)
  signature=$(menu_cache_signature)

  mkdir -p "$cache_dir"
  menu_json "$signature" >"$cache_file"
}

ensure_menu_cache() {
  local cache_file
  local signature
  local cached_signature

  cache_file=$(menu_cache_file)
  signature=$(menu_cache_signature)

  if [[ -s $cache_file ]]; then
    cached_signature=$(jq -r '.signature // empty' "$cache_file" 2>/dev/null || true)
    [[ $cached_signature == "$signature" ]] && return
  fi

  refresh_menu_cache
}

cached_menu_json() {
  local cache_file

  ensure_menu_cache
  cache_file=$(menu_cache_file)
  cat "$cache_file"
}

cached_menu_action() {
  local id="$1"
  local cache_file

  ensure_menu_cache
  cache_file=$(menu_cache_file)
  jq -r --arg id "$id" '.actions[$id] // empty' "$cache_file"
}

run_action() {
  local id="$1"
  local action

  action=$(cached_menu_action "$id") || return 0
  [[ -n $action ]] || return 0

  # Cached actions may call helper functions defined by user extensions.
  # Source extensions here without rebuilding the full menu so dispatch stays fast.
  source_menu_extensions
  eval "$action"
}

ensure_menu_style_file() {
  local toggles_dir="$HOME/.local/state/omarchy/toggles"
  local style_file="$toggles_dir/quickshell-menu.json"
  local radius=0

  [[ -f $style_file ]] && return

  mkdir -p "$toggles_dir"
  if [[ -f $toggles_dir/walker.css ]] && grep -q 'border-radius: 6px;' "$toggles_dir/walker.css"; then
    radius=6
  fi

  printf '{ "radius": %s }\n' "$radius" >"$style_file"
}

open_quickshell_menu() {
  local initial_menu="$1"
  local menu_payload
  local colors_file="$HOME/.config/omarchy/current/theme/menu.json"
  local colors_payload=""
  local font_family
  local menu_file
  local selection_file
  local done_file
  local socket_path
  local selected_id
  local menu_started=false

  if close_visible_quickshell_menu; then
    return
  fi

  ensure_menu_style_file

  socket_path=$(menu_socket_path)
  if [[ -S $socket_path ]] && ! menu_layer_visible; then
    quickshell kill -p "$(menu_qml_path)" >/dev/null 2>&1 || true
    rm -f "$socket_path"
  fi

  menu_payload=$(cached_menu_json)

  if [[ ! -f $colors_file ]]; then
    colors_file="$HOME/.config/omarchy/current/theme/background-switcher-colors.json"
  fi

  if [[ -f $colors_file ]]; then
    colors_payload=$(<"$colors_file")
    colors_payload=${colors_payload//$'\t'/$'\f'}
    colors_payload=${colors_payload//$'\n'/$'\v'}
  fi

  font_family=$(omarchy-font-current 2>/dev/null || true)
  font_family=${font_family:-monospace}

  menu_file=$(mktemp)
  selection_file=$(mktemp)
  done_file=$(mktemp)
  printf '%s' "$menu_payload" >"$menu_file"
  rm -f "$done_file"
  trap "rm -f $(shell_quote "$menu_file") $(shell_quote "$selection_file") $(shell_quote "$done_file")" EXIT

  env \
    OMARCHY_MENU_JSON_FILE="$menu_file" \
    OMARCHY_MENU_INITIAL_MENU="$initial_menu" \
    OMARCHY_MENU_SELECTION_FILE="$selection_file" \
    OMARCHY_MENU_DONE_FILE="$done_file" \
    OMARCHY_MENU_COLORS_RAW="$colors_payload" \
    OMARCHY_MENU_FONT="$font_family" \
    quickshell -d -p "$(menu_qml_path)" >/dev/null

  for (( i = 0; i < 500; i++ )); do
    if [[ -e $done_file ]] || { [[ -S $socket_path ]] && menu_layer_visible; }; then
      menu_started=true
      break
    fi
    sleep 0.01
  done

  if [[ $menu_started != true ]]; then
    quickshell kill -p "$(menu_qml_path)" >/dev/null 2>&1 || true
    rm -f "$socket_path"
    echo "omarchy-menu: Quickshell menu did not open" >&2
    return 1
  fi

  while [[ ! -e $done_file ]]; do
    sleep 0.01
  done

  quickshell kill -p "$(menu_qml_path)" >/dev/null 2>&1 || true
  rm -f "$socket_path"

  if [[ -s $selection_file ]]; then
    selected_id=$(<"$selection_file")
    run_action "$selected_id"
  fi
}

case "${1:-}" in
--prepare-only)
  ensure_menu_style_file
  cached_menu_json >/dev/null
  exit 0
  ;;
--dump)
  menu_json "$(menu_cache_signature)"
  exit 0
  ;;
esac

if [[ -z ${1:-} ]]; then
  open_quickshell_menu root
  exit 0
fi

target=$(route_target "${1:-}")
kind=$(route_kind "$target")

case "$kind" in
action)
  close_visible_quickshell_menu || true
  run_action "$target"
  ;;
menu)
  open_quickshell_menu "$target"
  ;;
link)
  open_quickshell_menu "$(route_link_target "$target")"
  ;;
*)
  open_quickshell_menu root
  ;;
esac
