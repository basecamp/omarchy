show_screensaver_menu() {
  case $(menu "Screensaver" "ïپ„  Edit Text\nï€¾  Set From Image\nï‘ھ  Restore Default") in
  *Text*) omarchy-branding-screensaver text ;;
  *Image*) omarchy-branding-screensaver image ;;
