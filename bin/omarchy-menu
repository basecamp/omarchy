#!/bin/bash

# omarchy:summary=Launch the Omarchy Menu or jump straight to a submenu/action
# omarchy:args=[apps|learn|trigger|capture|toggle|hardware|style|theme|background|setup|power|install|remove|update|system]

OMARCHY_PATH=${OMARCHY_PATH:-$HOME/.local/share/omarchy}

declare -a MENU_ORDER=()
declare -A MENU_PARENT=()
declare -A MENU_KIND=()
declare -A MENU_ICON=()
declare -A MENU_LABEL=()
declare -A MENU_TARGET=()
declare -A MENU_KEYWORDS=()
declare -A MENU_DESCRIPTION=()
declare -A MENU_ACTIONS=()

MENU_BUILT=false

shell_quote() {
  printf "'%s'" "${1//\'/\'\\\'\'}"
}

slugify() {
  local value="${1,,}"
  value="${value//[^a-z0-9]/-}"

  while [[ $value == *--* ]]; do
    value="${value//--/-}"
  done

  while [[ $value == -* ]]; do
    value="${value#-}"
  done

  while [[ $value == *- ]]; do
    value="${value%-}"
  done

  printf '%s' "${value:-item}"
}

register_item() {
  local parent="$1"
  local id="$2"
  local kind="$3"
  local icon="$4"
  local label="$5"
  local target="${6:-}"
  local keywords="${7:-}"
  local description="${8:-}"

  if [[ -z $id ]]; then
    echo "Menu item id is required" >&2
    return 1
  fi

  if [[ -z ${MENU_KIND[$id]} ]]; then
    MENU_ORDER+=("$id")
  fi

  MENU_PARENT[$id]="$parent"
  MENU_KIND[$id]="$kind"
  MENU_ICON[$id]="$icon"
  MENU_LABEL[$id]="$label"
  MENU_TARGET[$id]="$target"
  MENU_KEYWORDS[$id]="$keywords"
  MENU_DESCRIPTION[$id]="$description"
}

# Menu DSL used by the add_*_menu functions below.
#
# IDs are stable dotted paths that mirror where the row appears. For example,
# Install > Development > Go lives under parent "install.development" with an id
# like "install.development.go". Those ids are also accepted by `omarchy-menu`.
#
# Common fields:
#   parent-id   Existing menu that owns this row ("root", "root.install", ...)
#   id          Stable dotted id for this row
#   icon        Nerd Font glyph shown in the icon column
#   label       Visible row title
#   keywords    Extra words included in search, not displayed
#   description Optional subtitle/extra search text
#
# menu_group <parent-id> <id> <icon> <label> [keywords] [description]
#   Adds a submenu. Put its children in the matching add_<path>_menu function.
#
# menu_link <parent-id> <id> <icon> <label> <target-menu-id> [keywords] [description]
#   Adds a row that opens an already-defined submenu from another location.
#
# menu_action <parent-id> <id> <icon> <label> <command> [keywords] [description]
#   Adds an executable row. Commands are eval'd by run_action, so use
#   shell_quote when interpolating dynamic user/file values.
menu_group() {
  register_item "$1" "$2" menu "$3" "$4" "" "${5:-}" "${6:-}"
}

menu_link() {
  register_item "$1" "$2" link "$3" "$4" "$5" "${6:-}" "${7:-}"
}

menu_action() {
  local parent="$1"
  local id="$2"
  local icon="$3"
  local label="$4"
  local command="$5"
  local keywords="${6:-}"
  local description="${7:-}"

  register_item "$parent" "$id" action "$icon" "$label" "" "$keywords" "$description"
  MENU_ACTIONS[$id]="$command"
}

terminal() {
  xdg-terminal-exec --app-id=org.omarchy.terminal "$@"
}

present_terminal() {
  omarchy-launch-floating-terminal-with-presentation "$*"
}

open_in_editor() {
  omarchy-notification-send -u low "Editing config file" "$1"
  omarchy-launch-editor "$1"
}

hypr_config_file() {
  local name="$1"
  printf '%s/.config/hypr/%s.lua' "$HOME" "$name"
}

install() {
  present_terminal "echo 'Installing $1...'; omarchy-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; omarchy-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omarchy-pkg-add $2 && sleep 2 && omarchy-font-set '$3'"
}

install_terminal() {
  present_terminal "omarchy-install-terminal $1"
}

browser_desktop_exists() {
  [[ -f $HOME/.local/share/applications/$1 || -f $HOME/.nix-profile/share/applications/$1 || -f /usr/share/applications/$1 ]]
}

current_marker() {
  if [[ $1 == $2 ]]; then
    printf ' ✓'
  fi
}

show_theme_menu() {
  local theme
  theme=$(omarchy-theme-switcher)
  [[ -n $theme ]] && omarchy-theme-set "$theme"
}

show_background_menu() {
  local background
  background=$(omarchy-theme-bg-switcher)
  [[ -n $background ]] && omarchy-theme-bg-set "$background"
}

show_about() {
  omarchy-launch-about
}

show_custom_reminder_input() {
  local minutes
  minutes=$(omarchy-menu-input "Remind in minutes")

  if [[ $minutes =~ ^[0-9]+$ ]] && (( minutes > 0 )); then
    show_reminder_message_input "$minutes"
  elif [[ -n $minutes ]]; then
    omarchy-notification-send -g 󰔛 "Invalid reminder" "Enter the number of minutes" -u critical
    show_custom_reminder_input
  fi
}

show_reminder_message_input() {
  local minutes="$1"
  local message
  message=$(omarchy-menu-input "Reminder message")

  if [[ -n $message ]]; then
    omarchy-reminder "$minutes" "$message"
  else
    omarchy-reminder "$minutes"
  fi
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      local device
      IFS= read -r device || break
      device=$(tr -d '\t' <<<"$device" | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices
  local count
  devices=$(get_webcam_list)
  if [[ -z $devices ]]; then
    count=0
  else
    count=$(grep -c . <<<"$devices")
  fi

  if [[ -z $devices ]] || (( count == 0 )); then
    omarchy-notification-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if (( count == 1 )); then
    awk '{print $1}' <<<"$devices"
  else
    omarchy-menu-select "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

stop_active_screenrecording() {
  omarchy-capture-screenrecording --stop-recording
}

screenrecord_with_webcam() {
  local device
  device=$(show_webcam_select_menu) || return 1
  omarchy-capture-screenrecording --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
}

add_font_actions() {
  local current_font
  local index=0
  local font
  local label
  local id
  current_font=$(omarchy-font-current 2>/dev/null)

  while IFS= read -r font; do
    [[ -n $font ]] || continue
    (( index++ ))
    label="$font$(current_marker "$font" "$current_font")"
    id="style.font.$index.$(slugify "$font")"
    menu_action "style.font" "$id" "" "$label" "omarchy-font-set $(shell_quote "$font")" "$font typeface"
  done < <(omarchy-font-list 2>/dev/null)
}

add_power_profile_actions() {
  local current_profile
  local profile
  current_profile=$(powerprofilesctl get 2>/dev/null)

  while IFS= read -r profile; do
    [[ -n $profile ]] || continue
    menu_action "setup.power" "setup.power.$(slugify "$profile")" "󱐋" "$profile$(current_marker "$profile" "$current_profile")" "powerprofilesctl set $(shell_quote "$profile")" "$profile power profile"
  done < <(omarchy-powerprofiles-list 2>/dev/null)
}

add_default_browser_actions() {
  local current
  current=$(omarchy-default-browser 2>/dev/null)

  browser_desktop_exists chromium.desktop && menu_action "setup.default.browser" "setup.default.browser.chromium" "" "Chromium$(current_marker chromium "$current")" "omarchy-default-browser chromium" "default browser chromium"
  browser_desktop_exists google-chrome.desktop && menu_action "setup.default.browser" "setup.default.browser.chrome" "󰊯" "Chrome$(current_marker chrome "$current")" "omarchy-default-browser chrome" "default browser google chrome"
  browser_desktop_exists brave-browser.desktop && menu_action "setup.default.browser" "setup.default.browser.brave" "󰖟" "Brave$(current_marker brave "$current")" "omarchy-default-browser brave" "default browser brave"
  browser_desktop_exists brave-origin-beta.desktop && menu_action "setup.default.browser" "setup.default.browser.brave-origin" "󰖟" "Brave Origin$(current_marker brave-origin "$current")" "omarchy-default-browser brave-origin" "default browser brave origin"
  browser_desktop_exists microsoft-edge.desktop && menu_action "setup.default.browser" "setup.default.browser.edge" "󰇩" "Edge$(current_marker edge "$current")" "omarchy-default-browser edge" "default browser edge"
  browser_desktop_exists firefox.desktop && menu_action "setup.default.browser" "setup.default.browser.firefox" "󰈹" "Firefox$(current_marker firefox "$current")" "omarchy-default-browser firefox" "default browser firefox"
  browser_desktop_exists zen.desktop && menu_action "setup.default.browser" "setup.default.browser.zen" "󰖟" "Zen$(current_marker zen "$current")" "omarchy-default-browser zen" "default browser zen"
}

