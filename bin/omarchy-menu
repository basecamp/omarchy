show_setup_config_menu() {
  case $(menu "Setup" "ïچ™  Hyprland\nïچ™  Hypridle\nïچ™  Hyprlock\nïچ™  Hyprsunset\nïچ‌  Swayosd\nَ°Œ§  Walker\nَ°چœ  Waybar\nَ°‍…  XCompose") in
