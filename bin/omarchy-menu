  local current
  current=$(omarchy-default-terminal 2>/dev/null)

  omarchy-cmd-present alacritty && menu_action "setup.default.terminal" "setup.default.terminal.alacritty" "" "Alacritty$(current_marker alacritty "$current")" "omarchy-default-terminal alacritty" "default terminal alacritty"
  omarchy-cmd-present foot && menu_action "setup.default.terminal" "setup.default.terminal.foot" "" "Foot$(current_marker foot "$current")" "omarchy-default-terminal foot" "default terminal foot"
  omarchy-cmd-present ghostty && menu_action "setup.default.terminal" "setup.default.terminal.ghostty" "" "Ghostty$(current_marker ghostty "$current")" "omarchy-default-terminal ghostty" "default terminal ghostty"
  omarchy-cmd-present kitty && menu_action "setup.default.terminal" "setup.default.terminal.kitty" "" "Kitty$(current_marker kitty "$current")" "omarchy-default-terminal kitty" "default terminal kitty"
}

add_default_editor_actions() {
  local current
  current=$(omarchy-default-editor 2>/dev/null)

  omarchy-cmd-present nvim && menu_action "setup.default.editor" "setup.default.editor.neovim" "" "Neovim$(current_marker nvim "$current")" "omarchy-default-editor nvim" "default editor neovim nvim"
  omarchy-cmd-present code && menu_action "setup.default.editor" "setup.default.editor.vscode" "" "VSCode$(current_marker code "$current")" "omarchy-default-editor code" "default editor vscode code"
  omarchy-cmd-present cursor && menu_action "setup.default.editor" "setup.default.editor.cursor" "" "Cursor$(current_marker cursor "$current")" "omarchy-default-editor cursor" "default editor cursor"
  if omarchy-cmd-present zeditor; then
    menu_action "setup.default.editor" "setup.default.editor.zed" "" "Zed$(current_marker zed "$current")$(current_marker zeditor "$current")" "omarchy-default-editor zed" "default editor zed"
  fi
  omarchy-cmd-present sublime_text && menu_action "setup.default.editor" "setup.default.editor.sublime" "" "Sublime Text$(current_marker sublime_text "$current")" "omarchy-default-editor sublime_text" "default editor sublime text"
  omarchy-cmd-present helix && menu_action "setup.default.editor" "setup.default.editor.helix" "" "Helix$(current_marker helix "$current")" "omarchy-default-editor helix" "default editor helix"
  omarchy-cmd-present vim && menu_action "setup.default.editor" "setup.default.editor.vim" "" "Vim$(current_marker vim "$current")" "omarchy-default-editor vim" "default editor vim"
  omarchy-cmd-present emacs && menu_action "setup.default.editor" "setup.default.editor.emacs" "" "Emacs$(current_marker emacs "$current")" "omarchy-default-editor emacs" "default editor emacs"
}

add_hardware_actions() {
  menu_action "trigger.hardware" "trigger.hardware.laptop-display" "󰛧" "Laptop Display" "omarchy-hyprland-monitor-internal toggle" "hardware monitor laptop display"
  menu_action "trigger.hardware" "trigger.hardware.mirror-display" "󰍹" "Mirror Display" "omarchy-hyprland-monitor-internal-mirror toggle" "hardware monitor mirror display"

  if omarchy-hw-hybrid-gpu; then
    menu_action "trigger.hardware" "trigger.hardware.hybrid-gpu" "" "Hybrid GPU" "present_terminal omarchy-toggle-hybrid-gpu" "hardware graphics gpu"
  fi

  if omarchy-hw-touchpad >/dev/null; then
    menu_action "trigger.hardware" "trigger.hardware.touchpad" "󰟸" "Touchpad" "omarchy-toggle-touchpad" "hardware touchpad trackpad"
  fi

  if omarchy-hw-dell-xps-haptic-touchpad && omarchy-cmd-present dell-xps-touchpad-haptics; then
    local current_haptics
    current_haptics=$(dell-xps-touchpad-haptics get 2>/dev/null)
    menu_group "trigger.hardware" "trigger.hardware.touchpad-haptics" "󰌌" "Touchpad Haptics" "hardware touchpad haptics"
    menu_action "trigger.hardware.touchpad-haptics" "trigger.hardware.touchpad-haptics.low" "󰌌" "low$(current_marker low "$current_haptics")" "dell-xps-touchpad-haptics set low" "touchpad haptics low"
    menu_action "trigger.hardware.touchpad-haptics" "trigger.hardware.touchpad-haptics.mid" "󰌌" "mid$(current_marker mid "$current_haptics")" "dell-xps-touchpad-haptics set mid" "touchpad haptics mid medium"
    menu_action "trigger.hardware.touchpad-haptics" "trigger.hardware.touchpad-haptics.high" "󰌌" "high$(current_marker high "$current_haptics")" "dell-xps-touchpad-haptics set high" "touchpad haptics high"
  fi

  if omarchy-hw-touchscreen >/dev/null; then
    menu_action "trigger.hardware" "trigger.hardware.touchscreen" "󰆽" "Touchscreen" "omarchy-toggle-touchscreen" "hardware touchscreen tablet"
  fi
}

add_system_actions() {
  menu_action "root.system" "system.screensaver" "󱄄" "Screensaver" "omarchy-launch-screensaver force" "screensaver system"
  menu_action "root.system" "system.lock" "" "Lock" "omarchy-system-lock" "lock screen system"
  if ! omarchy-toggle-enabled suspend-off; then
    menu_action "root.system" "system.suspend" "󰒲" "Suspend" "systemctl suspend" "sleep suspend system"
  fi
  if omarchy-hibernation-available; then
    menu_action "root.system" "system.hibernate" "󰤁" "Hibernate" "systemctl hibernate" "sleep hibernate system"
  fi
  menu_action "root.system" "system.logout" "󰍃" "Logout" "omarchy-system-logout" "logout sign out system"
  menu_action "root.system" "system.restart" "󰜉" "Restart" "omarchy-system-reboot" "reboot restart system"
  menu_action "root.system" "system.shutdown" "󰐥" "Shutdown" "omarchy-system-shutdown" "power off shutdown system"
}

add_setup_sleep_actions() {
  if omarchy-toggle-enabled suspend-off; then
    menu_action "setup.sleep" "setup.sleep.suspend" "󰒲" "Enable Suspend" "omarchy-toggle-suspend" "system sleep suspend"
  else
    menu_action "setup.sleep" "setup.sleep.suspend" "󰒲" "Disable Suspend" "omarchy-toggle-suspend" "system sleep suspend"
  fi

  if omarchy-hibernation-available; then
    menu_action "setup.sleep" "setup.sleep.hibernate" "󰤁" "Disable Hibernate" "present_terminal omarchy-hibernation-remove" "system sleep hibernate"
  else
    menu_action "setup.sleep" "setup.sleep.hibernate" "󰤁" "Enable Hibernate" "present_terminal omarchy-hibernation-setup" "system sleep hibernate"
  fi
}

# Menu definition. Keep this grouped by the visible menu path so the file stays
# easy to scan. To add "Install > Development > Zig", edit
# add_install_development_menu. If you add a new submenu, register the group in
# its parent function and add a matching add_<path>_menu function for its rows.
build_menu() {
  add_root_menu
  add_learn_menu
  add_trigger_menu
  add_style_menu
  add_setup_menu
  add_install_menu
  add_remove_menu
  add_update_menu
  add_system_actions
}

