#!/bin/bash

# omarchy:summary=Add the named packages to the system from a Copr repo if they're missing.
# omarchy:args=<copr-repo> <packages...>
# omarchy:examples=omarchy pkg aur-add user/repo package-name
# NOTE: On Fedora, "AUR" packages are served via Copr. The first argument must
#       be the Copr repo in 'user/project' format; remaining args are package names.

if (($# < 2)); then
  echo "Usage: omarchy-pkg-aur-add <copr-user/project> <packages...>" >&2
  exit 1
fi

copr_repo="$1"
shift
packages=("$@")

# Enable Copr repo if not already enabled
if ! dnf copr list --enabled 2>/dev/null | grep -qF "$copr_repo"; then
  sudo dnf copr enable -y "$copr_repo" || exit 1
fi

omarchy-pkg-add "${packages[@]}"
