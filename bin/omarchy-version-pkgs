#!/bin/bash

# omarchy:summary=Print when system packages were last upgraded

# dnf history stores upgrades; extract the date of the last one
last_upgrade=$(dnf history list upgrade 2>/dev/null | awk 'NR==2 {print $3, $4}')
if [[ -n $last_upgrade ]]; then
  date -d "$last_upgrade" "+%A, %B %d %Y at %H:%M" 2>/dev/null || echo "$last_upgrade"
else
  echo "No upgrades recorded"
fi
