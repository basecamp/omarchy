#!/bin/bash

if omarchy-pkg-present steam; then # Only apply if steam is installed

  # Kill existing steam instances
  killall steam
# Launch steam with gamescope session
  gum confirm "The system will reboot, and once you login, you will be taken to steam" &&\
    sudo sed -i 's/^Session=.*/Session=gamescope-session-steam/' /etc/sddm.conf.d/autologin.conf && omarchy-system-reboot
else
  echo "please install steam first by running omarchy-install-steam"
fi

