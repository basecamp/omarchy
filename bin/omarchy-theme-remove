#!/bin/bash

# omarchy:summary=Remove a user-installed theme
# omarchy:args=[theme-name]
# omarchy:examples=omarchy theme remove "Tokyo Night"

set -euo pipefail

THEMES_DIR="$HOME/.config/omarchy/themes"
CURRENT_FILE="$HOME/.local/state/omarchy/current/theme.name"

valid_name() {
  [[ $1 =~ ^[A-Za-z0-9._-]+$ && $1 != "." && $1 != ".." ]]
}

theme_name=${1:-}
if [[ -z $theme_name ]]; then
  extra_themes=()
  if [[ -d $THEMES_DIR ]]; then
    mapfile -t extra_themes < <(find "$THEMES_DIR" -mindepth 1 -maxdepth 1 -type d ! -xtype l -printf '%f\n' | sort)
  fi

  if (( ${#extra_themes[@]} == 0 )); then
    printf 'No extra themes installed.\n'
    exit 1
  fi

  theme_name=$(omarchy-menu-select "Remove extra theme" "${extra_themes[@]}" -- --width 520 --maxheight 520)
fi

[[ -n $theme_name ]] || exit 1
if ! valid_name "$theme_name"; then
  printf 'Invalid theme name: %s\n' "$theme_name" >&2
  exit 64
fi

current_theme=""
if [[ -r $CURRENT_FILE ]]; then
  current_theme=$(tr -d '[:space:]' <"$CURRENT_FILE" 2>/dev/null || true)
fi
if [[ $theme_name == "$current_theme" ]]; then
  printf 'Cannot remove the active theme. Select another theme first.\n' >&2
  exit 1
fi

theme_path="$THEMES_DIR/$theme_name"
if [[ ! -d $theme_path || -L $theme_path ]]; then
  printf "Theme '%s' is not an installed user theme.\n" "$theme_name" >&2
  exit 1
fi

rm -rf -- "$theme_path"
omarchy-notification-send "Theme removed" "$theme_name" || true
printf 'Removed %s\n' "$theme_name"
