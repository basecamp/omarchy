#!/bin/bash

# omarchy:summary=Ensure the Omarchy GPG key is imported into rpm keyring
# omarchy:requires-sudo=true

OMARCHY_KEY_ID="40DFB630FF42BCFFB047046CF0134EE680CAC571"
OMARCHY_KEY_URL="https://keys.openpgp.org/vks/v1/by-fingerprint/$OMARCHY_KEY_ID"

if ! rpm -q gpg-pubkey --queryformat "%{SUMMARY}\n" 2>/dev/null | grep -q "${OMARCHY_KEY_ID: -8}"; then
  echo -e "\e[32m\nImporting Omarchy GPG key\e[0m"
  curl -sf "$OMARCHY_KEY_URL" | sudo rpm --import -
fi

# Ensure Fedora signing keys are up to date
echo -e "\e[32m\nUpdate Fedora signing keys\e[0m"
sudo dnf upgrade -y fedora-gpg-keys &>/dev/null || true
echo "Keys are correct"
