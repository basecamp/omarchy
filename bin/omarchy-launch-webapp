#!/bin/bash

# omarchy:summary=Launch a URL as a web app in the default supported browser
# omarchy:args=<url>

browser=$(xdg-settings get default-web-browser)

case $browser in
google-chrome* | brave* | microsoft-edge* | opera* | vivaldi* | helium*) ;;
*) browser="chromium.desktop" ;;
esac

browser_exec=$(sed -n 's/^Exec=\([^ ]*\).*/\1/p' \
  {~/.local,~/.nix-profile,/usr}/share/applications/$browser \
  2>/dev/null | head -1)

[[ -n "$browser_exec" ]] || browser_exec=$(command -v microsoft-edge-stable)

exec setsid uwsm-app -- "$browser_exec" --app="$1" "${@:2}"
