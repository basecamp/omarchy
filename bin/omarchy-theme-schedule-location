#!/bin/bash

# omarchy:summary=Print effective lat,long for theme scheduling
# omarchy:hidden=true

set -euo pipefail

override="$HOME/.config/omarchy/theme-schedule.location"
if [[ -f "$override" ]]; then
  cat "$override"
  exit 0
fi

tz=""
if [[ -L /etc/localtime ]]; then
  tz=$(readlink /etc/localtime | sed 's|.*zoneinfo/||')
fi
if [[ -z "$tz" && -f /etc/timezone ]]; then
  tz=$(<"/etc/timezone")
fi
if [[ -z "$tz" ]]; then
  echo "Could not determine system timezone" >&2
  exit 1
fi

zonetab=/usr/share/zoneinfo/zone1970.tab
if [[ ! -f "$zonetab" ]]; then
  zonetab=/usr/share/zoneinfo/zone.tab
fi
if [[ ! -f "$zonetab" ]]; then
  echo "Could not find zone.tab in /usr/share/zoneinfo" >&2
  exit 1
fi

# Match against column 3 (zone1970.tab) or column 3 (zone.tab) — same column number.
coord=$(awk -F'\t' -v tz="$tz" '$1 !~ /^#/ && $3 == tz { print $2; exit }' "$zonetab")
if [[ -z "$coord" ]]; then
  echo "Could not find timezone $tz in $zonetab" >&2
  exit 1
fi

# ISO 6709 short form: ±DDMM±DDDMM or ±DDMMSS±DDDMMSS
if [[ $coord =~ ^([+-])([0-9]{2})([0-9]{2})([0-9]{2})?([+-])([0-9]{3})([0-9]{2})([0-9]{2})?$ ]]; then
  lat=$(awk -v s="${BASH_REMATCH[1]}" -v d="${BASH_REMATCH[2]}" -v m="${BASH_REMATCH[3]}" -v sec="${BASH_REMATCH[4]:-0}" \
    'BEGIN { v = d + m/60 + sec/3600; if (s == "-") v = -v; printf "%.4f", v }')
  lon=$(awk -v s="${BASH_REMATCH[5]}" -v d="${BASH_REMATCH[6]}" -v m="${BASH_REMATCH[7]}" -v sec="${BASH_REMATCH[8]:-0}" \
    'BEGIN { v = d + m/60 + sec/3600; if (s == "-") v = -v; printf "%.4f", v }')
  echo "$lat,$lon"
else
  echo "Could not parse coordinate '$coord' for timezone $tz" >&2
  exit 1
fi
