#!/bin/bash

# omarchy:summary=Show a fuzzy-finder TUI for picking new Copr packages to install.
# omarchy:requires-sudo=true
# NOTE: On Fedora, "AUR packages" are served via Copr repositories.
#       This tool browses the available packages across all enabled Copr repos.

fzf_args=(
  --multi
  --preview 'dnf info {1} 2>/dev/null || echo "No info available"'
  --preview-label='alt-p: toggle description, alt-j/k: scroll, tab: multi-select'
  --preview-label-pos='bottom'
  --preview-window 'down:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
  --color 'pointer:green,marker:green'
)

# List packages from all enabled Copr repos
pkg_names=$(dnf repoquery --queryformat '%{name}' --repo "copr:*" 2>/dev/null | sort -u | fzf "${fzf_args[@]}")

if [[ -n $pkg_names ]]; then
  source omarchy-sudo-keepalive
  echo "$pkg_names" | tr '\n' ' ' | xargs sudo dnf install -y
  omarchy-show-done
fi
