#!/bin/bash

# Designed to be run by systemd timer every 30 seconds and trigger the omarchy battery monitor hook.

BATTERY_LEVEL=$(omarchy-battery-remaining)
BATTERY_STATE=$(upower -i $(upower -e | grep 'BAT') | grep -E "state" | awk '{print $2}')

if [[ -n $BATTERY_LEVEL && $BATTERY_LEVEL =~ ^[0-9]+$ ]]; then
  omarchy-hook battery-monitor "$BATTERY_LEVEL" "$BATTERY_STATE"
fi
