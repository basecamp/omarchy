#!/bin/bash

# omarchy:summary=Reinstall all default Omarchy packages from the stable channel
# omarchy:requires-sudo=true

set -e

# Reset DNF repo configuration to the stable Omarchy channel
omarchy-refresh-dnf

# Ensure all base packages are installed
mapfile -t packages < <(grep -v '^#' "$OMARCHY_PATH/install/omarchy-base.packages" | grep -v '^$')
sudo dnf install -y --allowerasing "${packages[@]}"
