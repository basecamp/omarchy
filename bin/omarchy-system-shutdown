#!/bin/bash

# omarchy:summary=Shut down after closing application windows
# omarchy:examples=omarchy shutdown | omarchy system shutdown
# omarchy:aliases=omarchy shutdown

window_count=$(hyprctl clients -j | jq length)

omarchy-state clear re*-required

if ((window_count > 0)); then
  timeout 2s omarchy-hyprland-window-close-all && sleep 1 || true
fi

exec systemctl poweroff --no-wall
