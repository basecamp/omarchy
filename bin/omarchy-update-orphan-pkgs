#!/bin/bash

# omarchy:summary=Remove orphaned system packages after updates
# omarchy:requires-sudo=true

# Find packages that were installed as dependencies but are no longer needed
orphans=$(dnf repoquery --unneeded --quiet 2>/dev/null | grep -v '^$' || true)
if [[ -n $orphans ]]; then
  echo -e "\e[32m\nRemove orphan system packages\e[0m"
  echo "$orphans" | xargs sudo dnf remove -y || true
  echo
fi
