#!/bin/bash

# omarchy:summary=Returns true if a Copr or third-party repo is up and available.
# (Replaces the Arch AUR accessibility check — Fedora uses Copr instead of AUR.)

curl -sf --connect-timeout 30 --retry 3 --retry-delay 3 -A "omarchy-update" \
  "https://copr.fedorainfracloud.org/api_3/project/search/?query=omarchy" >/dev/null
