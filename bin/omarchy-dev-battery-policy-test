#!/bin/bash

# Apply or unapply the battery policy development changes from this checkout
# to the live Omarchy install in ~/.local/share/omarchy/bin.

set -eEuo pipefail

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
SOURCE_ROOT=$(readlink -f "$SCRIPT_DIR/..")
TARGET_ROOT=$(readlink -f "${OMARCHY_PATH:-$HOME/.local/share/omarchy}")
STATE_BASE="$HOME/.local/state/omarchy/dev/battery-policy-test"
TARGET_KEY=$(printf '%s' "$TARGET_ROOT" | sha256sum | cut -d' ' -f1)
STATE_ROOT="$STATE_BASE/$TARGET_KEY"
BACKUP_ROOT="$STATE_ROOT/backup"

FILES=(
  bin/omarchy-menu
  # The battery policy scripts below no longer live in this repo — they are
  # provided by the omarchy-battery-policy AUR package. Listing them here
  # causes sync_live_file to remove any stale copies from the live install.
  bin/omarchy-battery-policy-provider
  bin/omarchy-battery-policy-available
  bin/omarchy-battery-policy-status
  bin/omarchy-battery-policy-list
  bin/omarchy-battery-policy-set
  bin/omarchy-battery-policy-set-custom
  bin/omarchy-battery-policy-provider-dell-sysman
  bin/omarchy-battery-policy-provider-power-supply
  bin/omarchy-setup-battery-policy
  bin/omarchy-battery-threshold-available
  bin/omarchy-battery-threshold-toggle
)

# Legacy helper versions did not store a manifest. Keep the original managed
# file set here so those states can still be unapplied correctly.
LEGACY_FILES=(
  bin/omarchy-menu
  bin/omarchy-battery-policy-provider
  bin/omarchy-battery-policy-available
  bin/omarchy-battery-policy-status
  bin/omarchy-battery-policy-list
  bin/omarchy-battery-policy-set
  bin/omarchy-battery-policy-set-custom
  bin/omarchy-battery-policy-provider-dell-sysman
  bin/omarchy-battery-policy-provider-power-supply
  bin/omarchy-setup-battery-policy
  bin/omarchy-battery-threshold-available
  bin/omarchy-battery-threshold-toggle
)

usage() {
  cat <<USAGE
Usage: $0 <apply|unapply|status>

  apply    Copy the battery policy changes from this repo into $TARGET_ROOT
  unapply  Restore the original live files from backup
  status   Show whether the live install currently has the test patch applied
USAGE
}

path_list_contains() {
  local needle="$1"
  shift

  local path
  for path in "$@"; do
    [[ $path == "$needle" ]] && return 0
  done

  return 1
}

load_managed_files() {
  if [[ -f $STATE_ROOT/files ]]; then
    mapfile -t managed_files < "$STATE_ROOT/files"
  else
    managed_files=("${LEGACY_FILES[@]}")
  fi
}

save_managed_files() {
  local output_file="$1"
  shift

  printf '%s\n' "$@" > "$output_file"
}

ensure_paths() {
  if [[ ! -d $TARGET_ROOT/bin ]]; then
    echo "Live Omarchy install not found at $TARGET_ROOT/bin" >&2
    exit 1
  fi

  if [[ $SOURCE_ROOT == $TARGET_ROOT ]]; then
    echo "Run this helper from your repo checkout, not from the live Omarchy install." >&2
    exit 1
  fi
}

backup_live_file() {
  local relative_path="$1"
  local backup_root="$2"
  local live_path="$TARGET_ROOT/$relative_path"
  local backup_path="$backup_root/$relative_path"

  [[ -e $live_path ]] || return 0
  [[ -e $backup_path ]] && return 0

  mkdir -p "$(dirname "$backup_path")"
  cp -a "$live_path" "$backup_path"
}

sync_live_file() {
  local relative_path="$1"
  local source_path="$SOURCE_ROOT/$relative_path"
  local live_path="$TARGET_ROOT/$relative_path"

  if [[ -e $source_path ]]; then
    mkdir -p "$(dirname "$live_path")"
    install -m 0755 "$source_path" "$live_path"
  else
    rm -f "$live_path"
  fi
}

restore_file() {
  local relative_path="$1"
  local backup_root="$2"
  local live_path="$TARGET_ROOT/$relative_path"
  local backup_path="$backup_root/$relative_path"

  if [[ -e $backup_path ]]; then
    mkdir -p "$(dirname "$live_path")"
    cp -a "$backup_path" "$live_path"
  else
    rm -f "$live_path"
  fi
}

live_matches_checkout() {
  local relative_path
  local source_path
  local live_path
  local -a managed_files=()
  local -a check_files=()

  [[ -d $STATE_ROOT ]] || return 1

  load_managed_files
  check_files=("${managed_files[@]}")

  for relative_path in "${FILES[@]}"; do
    if ! path_list_contains "$relative_path" "${check_files[@]}"; then
      check_files+=("$relative_path")
    fi
  done

  for relative_path in "${check_files[@]}"; do
    source_path="$SOURCE_ROOT/$relative_path"
    live_path="$TARGET_ROOT/$relative_path"

    if [[ -e $source_path ]]; then
      [[ -e $live_path ]] || return 1
      cmp -s "$source_path" "$live_path" || return 1
    else
      [[ ! -e $live_path ]] || return 1
    fi
  done

  return 0
}

apply_changes() {
  local relative_path
  local temp_root
  local temp_backup_root
  local state_meta_backup
  local temp_new_original_backup_root
  local temp_removed_original_backup_root
  local rollback_path
  local -a processed_files=()
  local -a managed_files=()
  local -a new_managed_files=()
  local -a removed_managed_files=()

  ensure_paths

  if [[ -d $STATE_ROOT ]]; then
    temp_root=$(mktemp -d "$STATE_BASE/.update.${TARGET_KEY}.XXXXXX")
    temp_backup_root="$temp_root/backup"
    state_meta_backup="$temp_root/state"
    temp_new_original_backup_root="$temp_root/new-original-backup"
    temp_removed_original_backup_root="$temp_root/removed-original-backup"
    mkdir -p "$state_meta_backup"

    for relative_path in target-root source-root files; do
      if [[ -e $STATE_ROOT/$relative_path ]]; then
        cp -a "$STATE_ROOT/$relative_path" "$state_meta_backup/$relative_path"
      fi
    done

    rollback_apply() {
      local index

      for (( index = ${#processed_files[@]} - 1; index >= 0; index-- )); do
        rollback_path=${processed_files[$index]}
        restore_file "$rollback_path" "$temp_backup_root"
      done

      for rollback_path in "${new_managed_files[@]}"; do
        rm -f "$BACKUP_ROOT/$rollback_path"
      done

      for rollback_path in "${removed_managed_files[@]}"; do
        if [[ -e $temp_removed_original_backup_root/$rollback_path ]]; then
          mkdir -p "$(dirname "$BACKUP_ROOT/$rollback_path")"
          mv "$temp_removed_original_backup_root/$rollback_path" "$BACKUP_ROOT/$rollback_path"
        fi
      done

      for rollback_path in target-root source-root files; do
        if [[ -e $state_meta_backup/$rollback_path ]]; then
          cp -a "$state_meta_backup/$rollback_path" "$STATE_ROOT/$rollback_path"
        else
          rm -f "$STATE_ROOT/$rollback_path"
        fi
      done

      rm -rf "$temp_root"
    }

    trap rollback_apply ERR

    load_managed_files

    for relative_path in "${FILES[@]}"; do
      if ! path_list_contains "$relative_path" "${managed_files[@]}"; then
        backup_live_file "$relative_path" "$temp_new_original_backup_root"
        new_managed_files+=("$relative_path")
        managed_files+=("$relative_path")
      fi

      backup_live_file "$relative_path" "$temp_backup_root"
      processed_files+=("$relative_path")
      sync_live_file "$relative_path"
    done

    for relative_path in "${managed_files[@]}"; do
      if ! path_list_contains "$relative_path" "${FILES[@]}"; then
        backup_live_file "$relative_path" "$temp_backup_root"
        processed_files+=("$relative_path")
        restore_file "$relative_path" "$BACKUP_ROOT"
        removed_managed_files+=("$relative_path")
      fi
    done

    for relative_path in "${new_managed_files[@]}"; do
      if [[ -e $temp_new_original_backup_root/$relative_path ]]; then
        mkdir -p "$(dirname "$BACKUP_ROOT/$relative_path")"
        cp -a "$temp_new_original_backup_root/$relative_path" "$BACKUP_ROOT/$relative_path"
      fi
    done

    for relative_path in "${removed_managed_files[@]}"; do
      if [[ -e $BACKUP_ROOT/$relative_path ]]; then
        mkdir -p "$(dirname "$temp_removed_original_backup_root/$relative_path")"
        mv "$BACKUP_ROOT/$relative_path" "$temp_removed_original_backup_root/$relative_path"
      fi
    done

    printf '%s\n' "$TARGET_ROOT" > "$STATE_ROOT/target-root"
    printf '%s\n' "$SOURCE_ROOT" > "$STATE_ROOT/source-root"
    save_managed_files "$STATE_ROOT/files" "${FILES[@]}"
    trap - ERR
    rm -rf "$temp_root"

    echo "Updated battery policy test files in $TARGET_ROOT/bin"
    echo "Close any open Omarchy menu and reopen it before testing."
    return
  fi

  mkdir -p "$STATE_BASE"
  temp_root=$(mktemp -d "$STATE_BASE/.${TARGET_KEY}.XXXXXX")
  temp_backup_root="$temp_root/backup"

  rollback_apply() {
    local index

    for (( index = ${#processed_files[@]} - 1; index >= 0; index-- )); do
      rollback_path=${processed_files[$index]}
      restore_file "$rollback_path" "$temp_backup_root"
    done

    rm -rf "$temp_root"
  }

  trap rollback_apply ERR

  printf '%s\n' "$TARGET_ROOT" > "$temp_root/target-root"
  printf '%s\n' "$SOURCE_ROOT" > "$temp_root/source-root"
  save_managed_files "$temp_root/files" "${FILES[@]}"

  for relative_path in "${FILES[@]}"; do
    backup_live_file "$relative_path" "$temp_backup_root"
    processed_files+=("$relative_path")
    sync_live_file "$relative_path"
  done

  mv "$temp_root" "$STATE_ROOT"
  trap - ERR

  echo "Applied battery policy test files into $TARGET_ROOT/bin"
  echo "Close any open Omarchy menu and reopen it before testing."
}

unapply_changes() {
  local relative_path
  local -a managed_files=()

  ensure_paths

  if [[ ! -d $STATE_ROOT ]]; then
    echo "No battery policy test backup found at $STATE_ROOT" >&2
    exit 1
  fi

  if [[ -f $STATE_ROOT/target-root ]] && [[ $(<"$STATE_ROOT/target-root") != $TARGET_ROOT ]]; then
    echo "Saved battery policy test backup belongs to a different Omarchy install." >&2
    exit 1
  fi

  load_managed_files

  for relative_path in "${managed_files[@]}"; do
    restore_file "$relative_path" "$BACKUP_ROOT"
  done

  rm -rf "$STATE_ROOT"

  echo "Restored the original Omarchy battery files in $TARGET_ROOT/bin"
}

show_status() {
  ensure_paths

  if [[ -d $STATE_ROOT ]]; then
    if live_matches_checkout; then
      echo "battery-policy-test=applied"
    else
      echo "battery-policy-test=out-of-sync"
    fi

    if [[ -f $STATE_ROOT/source-root ]]; then
      echo "source-root=$(<"$STATE_ROOT/source-root")"
    fi
  else
    echo "battery-policy-test=not-applied"
  fi
}

case "${1:-}" in
apply) apply_changes ;;
unapply) unapply_changes ;;
status) show_status ;;
*) usage; exit 1 ;;
esac
