depends=(openrazer-daemon)

aur_depends=()

# DKMS requires headers for the running kernel. Setting needs_kernel_headers
# tells hwtool to add the appropriate *-headers package for whichever
# kernel(s) are installed (linux, linux-lts, linux-zen, etc.).
needs_kernel_headers=true

# openrazer-daemon is a per-user systemd unit; we enable it as a user
# service rather than letting DBus autostart handle it. This gives the
# user a working daemon on login without needing them to run anything.
services=()
services_user=(openrazer-daemon.service)

groups=(openrazer)

kernel_params=()

requires_reboot='DKMS kernel module needs reboot if headers were just installed'

post_install() {
    # DKMS module is built by the package's install hook. Try to load it
    # for the running kernel, but a reboot is the recommended fix if this
    # fails (often because headers were just installed in the same run).
    if ! modprobe razerkbd 2>/dev/null; then
        echo "razerkbd module did not load; a reboot is required." >&2
    fi
}
