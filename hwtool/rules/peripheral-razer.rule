# Maintainer: your name <you@example.com>
# Rule: Razer peripherals supported by OpenRazer
#
# OpenRazer provides a DKMS kernel driver and userspace daemon for Razer
# devices. This rule matches against the canonical list of supported PIDs
# published by the OpenRazer project.
#
# Canonical source:
#   https://openrazer.github.io/api/devices.json
#
# That endpoint is the project's own API, served from the openrazer.github.io
# repo's main branch. It includes both `pid` (primary product ID) and
# `alias_ids` (variant product IDs that share the same driver).
#
# To regenerate the match_value array below, run tools/sync-razer.sh and
# replace the array contents with its output.
#
# Notes:
#  - All Razer devices use VID 1532. PIDs are uppercase in the JSON
#    (e.g., "00B2") but lsusb emits lowercase ("00b2"). We normalize to
#    lowercase here to match lsusb output.
#  - DKMS requires kernel headers for whatever kernel(s) are installed.
#    The `needs_kernel_headers=true` field below tells hwtool to expand
#    that into the right `*-headers` package(s) automatically.
#  - User group changed from `plugdev` to `openrazer` in November 2025.
#  - A reboot is required after install for DKMS module + group to apply.

rulename='peripheral.razer'
ruledesc='OpenRazer driver and daemon for Razer peripherals'

match_type='usb_vidpid_any'

# Generated from https://openrazer.github.io/api/devices.json
# Regenerate with: tools/sync-razer.sh
# then paste the match_value=(...) block into rules/peripheral-razer.rule
# Last sync: 2026-04-28  (UTC)
# 267 PIDs (primary + alias_ids), sorted, deduplicated
match_value=(
  1532:0013 1532:0015 1532:0016 1532:001f 1532:0020 1532:0024 1532:0025
  1532:0029 1532:002e 1532:002f 1532:0032 1532:0034 1532:0036 1532:0037
  1532:0038 1532:0039 1532:003e 1532:003f 1532:0040 1532:0041 1532:0042
  1532:0043 1532:0044 1532:0045 1532:0046 1532:0048 1532:004c 1532:004f
  1532:0050 1532:0053 1532:0054 1532:0059 1532:005a 1532:005b 1532:005c
  1532:005e 1532:0060 1532:0062 1532:0064 1532:0065 1532:0067 1532:0068
  1532:006a 1532:006b 1532:006c 1532:006e 1532:006f 1532:0070 1532:0071
