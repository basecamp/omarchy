#!/bin/bash
# Migration: Add Vibe Bar AI agents Waybar indicator

WAYBAR_CONFIG="$HOME/.config/waybar/config.jsonc"
WAYBAR_CSS="$HOME/.config/waybar/style.css"

echo "Adding Vibe Bar to Waybar configuration..."

# 1. Add module to modules-center using jq (safe JSON parsing)
if [[ -f "$WAYBAR_CONFIG" ]] && ! grep -q "custom/vibe-bar" "$WAYBAR_CONFIG"; then
    # Create a temporary file
    TMP_JSON=$(mktemp)
    
    # Use jq to:
    # 1. Add "custom/vibe-bar" to modules-center (after custom/voxtype if it exists, or at the end)
    # 2. Add the custom/vibe-bar object definition at the root
    jq '
        .["modules-center"] |= (
            index("custom/voxtype") as $idx | 
            if $idx then 
                .[0:$idx+1] + ["custom/vibe-bar"] + .[$idx+1:] 
            else 
                . + ["custom/vibe-bar"] 
            end
        ) |
        .["custom/vibe-bar"] = {
            "exec": "$OMARCHY_PATH/default/vibe-bar/waybar_status.sh",
            "return-type": "json",
            "interval": 1,
            "signal": 11,
            "on-click": "omarchy-vibe-bar panel",
            "tooltip": true
        }
    ' "$WAYBAR_CONFIG" > "$TMP_JSON"
    
    mv "$TMP_JSON" "$WAYBAR_CONFIG"
    echo "  -> Added module configuration"
fi

# 2. Add CSS safely (append to the end if not present)
if [[ -f "$WAYBAR_CSS" ]] && ! grep -q "#custom-vibe-bar" "$WAYBAR_CSS"; then
    cat >> "$WAYBAR_CSS" << 'CSS_EOF'

/* Vibe Bar styling */
#custom-vibe-bar {
  min-width: 12px;
  margin: 0 7.5px;
  font-size: 12px;
}

#custom-vibe-bar.agents-idle {
  opacity: 0.4;
}

#custom-vibe-bar.agents-active {
  color: @foreground;
}

#custom-vibe-bar.agents-waiting {
  color: #f9a825;
  animation: vibe-bar-pulse 1.2s ease-in-out infinite;
}

@keyframes vibe-bar-pulse {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}
CSS_EOF
    echo "  -> Added CSS styling"
fi

# 3. Enable the user service and restart Waybar to apply
echo "Enabling omarchy-vibe-bar service..."
systemctl --user enable --now omarchy-vibe-bar 2>/dev/null || true

echo "Restarting Waybar..."
omarchy-restart-waybar
